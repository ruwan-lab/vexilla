#!/usr/bin/make -f
# -*- makefile -*-
export DH_VERBOSE = 1
export PYBUILD_NAME = vexilla

%:
	dh $@ --with python3

override_dh_auto_install:
	python3 -m pip install --root=$(CURDIR)/debian/vexilla --prefix=/usr .

override_dh_install:
	dh_install

override_dh_installsystemd:
	dh_installsystemd --no-enable
